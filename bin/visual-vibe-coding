#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if [[ -n "${PYTHONPATH:-}" ]]; then
  export PYTHONPATH="${SKILL_ROOT}:${PYTHONPATH}"
else
  export PYTHONPATH="${SKILL_ROOT}"
fi

exec python3 -m visual_vibe_coding_skill.cli "$@"
